{
  "project": {
    "name": "Parametric Hinge",
    "slug": "hinge-hyperobject",
    "version": "1.0.0",
    "description": {
      "en": "Parametric print-in-place hinges — living hinge, pin hinge, and ball joint for mechanical assemblies\n\nOfficial Visualizer and Configurator: Yantra4D",
      "es": "Bisagras paramétricas impresas en sitio — bisagra viva, bisagra de pasador y junta esférica para ensamblajes mecánicos\n\nVisualizador y configurador oficial: Yantra4D"
    },
    "thumbnail": "/projects/hinge-hyperobject.webp",
    "tags": [
      "mechanical",
      "hinge",
      "print-in-place",
      "hyperobject",
      "commons"
    ],
    "difficulty": "intermediate"
  },
  "modes": [
    {
      "id": "living_hinge",
      "scad_file": "living_hinge.scad",
      "label": {
        "en": "Living Hinge",
        "es": "Bisagra Viva"
      },
      "parts": [
        "hinge_body"
      ],
      "estimate": {
        "base_units": 1,
        "formula": "constant"
      }
    },
    {
      "id": "pin_hinge",
      "scad_file": "pin_hinge.scad",
      "label": {
        "en": "Pin Hinge",
        "es": "Bisagra de Pasador"
      },
      "parts": [
        "hinge_body"
      ],
      "estimate": {
        "base_units": 1,
        "formula": "constant"
      }
    },
    {
      "id": "ball_joint",
      "scad_file": "ball_joint.scad",
      "label": {
        "en": "Ball Joint",
        "es": "Junta Esférica"
      },
      "parts": [
        "hinge_body"
      ],
      "estimate": {
        "base_units": 1,
        "formula": "constant"
      }
    }
  ],
  "parts": [
    {
      "id": "hinge_body",
      "render_mode": 0,
      "label": {
        "en": "Hinge Body",
        "es": "Cuerpo de Bisagra"
      },
      "default_color": "#4a4a4a"
    }
  ],
  "presets": [
    {
      "id": "cabinet_hinge",
      "label": {
        "en": "Cabinet Hinge",
        "es": "Bisagra de Gabinete"
      },
      "mode": "pin_hinge",
      "values": {
        "hinge_width": 50,
        "leaf_length": 40,
        "pin_diameter": 4,
        "num_knuckles": 4
      }
    },
    {
      "id": "box_lid",
      "label": {
        "en": "Box Lid",
        "es": "Tapa de Caja"
      },
      "mode": "living_hinge",
      "values": {
        "hinge_width": 30,
        "leaf_length": 20,
        "hinge_thickness": 0.5
      }
    },
    {
      "id": "robot_joint",
      "label": {
        "en": "Robot Joint",
        "es": "Articulación de Robot"
      },
      "mode": "ball_joint",
      "values": {
        "socket_diameter": 20,
        "clearance": 0.3
      }
    }
  ],
  "parameters": [
    {
      "id": "hinge_width",
      "type": "slider",
      "default": 30,
      "min": 10,
      "max": 100,
      "step": 1,
      "label": {
        "en": "Hinge Width (mm)",
        "es": "Ancho de Bisagra (mm)"
      },
      "visible_in_modes": [
        "living_hinge",
        "pin_hinge",
        "ball_joint"
      ],
      "group": "dimensions"
    },
    {
      "id": "hinge_thickness",
      "type": "slider",
      "default": 0.6,
      "min": 0.3,
      "max": 2.0,
      "step": 0.1,
      "label": {
        "en": "Web Thickness (mm)",
        "es": "Espesor de Alma (mm)"
      },
      "tooltip": {
        "en": "Living hinge flexible web thickness",
        "es": "Espesor del alma flexible de la bisagra viva"
      },
      "visible_in_modes": [
        "living_hinge"
      ],
      "group": "joint"
    },
    {
      "id": "leaf_length",
      "type": "slider",
      "default": 30,
      "min": 15,
      "max": 80,
      "step": 1,
      "label": {
        "en": "Leaf Length (mm)",
        "es": "Longitud de Hoja (mm)"
      },
      "visible_in_modes": [
        "living_hinge",
        "pin_hinge",
        "ball_joint"
      ],
      "group": "dimensions"
    },
    {
      "id": "pin_diameter",
      "type": "slider",
      "default": 4,
      "min": 2,
      "max": 8,
      "step": 0.5,
      "label": {
        "en": "Pin Diameter (mm)",
        "es": "Diámetro del Pasador (mm)"
      },
      "visible_in_modes": [
        "pin_hinge"
      ],
      "group": "joint"
    },
    {
      "id": "clearance",
      "type": "slider",
      "default": 0.4,
      "min": 0.2,
      "max": 1.0,
      "step": 0.1,
      "label": {
        "en": "Clearance (mm)",
        "es": "Holgura (mm)"
      },
      "tooltip": {
        "en": "Gap between moving parts for print-in-place",
        "es": "Espacio entre partes móviles para impresión en sitio"
      },
      "visible_in_modes": [
        "pin_hinge",
        "ball_joint"
      ],
      "group": "joint"
    },
    {
      "id": "bend_angle",
      "type": "slider",
      "default": 90,
      "min": 0,
      "max": 180,
      "step": 1,
      "label": {
        "en": "Bend Angle (°)",
        "es": "Ángulo de Flexión (°)"
      },
      "visible_in_modes": [
        "living_hinge"
      ],
      "group": "joint"
    },
    {
      "id": "num_knuckles",
      "type": "slider",
      "default": 4,
      "min": 2,
      "max": 8,
      "step": 1,
      "label": {
        "en": "Number of Knuckles",
        "es": "Número de Nudillos"
      },
      "visible_in_modes": [
        "pin_hinge"
      ],
      "group": "joint"
    },
    {
      "id": "socket_diameter",
      "type": "slider",
      "default": 15,
      "min": 8,
      "max": 25,
      "step": 1,
      "label": {
        "en": "Socket Diameter (mm)",
        "es": "Diámetro de Cavidad (mm)"
      },
      "visible_in_modes": [
        "ball_joint"
      ],
      "group": "joint"
    },
    {
      "id": "fn",
      "type": "slider",
      "default": 0,
      "min": 0,
      "max": 64,
      "step": 8,
      "label": {
        "en": "Quality ($fn)",
        "es": "Calidad ($fn)"
      },
      "visible_in_modes": [
        "living_hinge",
        "pin_hinge",
        "ball_joint"
      ],
      "group": "quality",
      "visibility_level": "advanced"
    }
  ],
  "parameter_groups": [
    {
      "id": "dimensions",
      "label": {
        "en": "Dimensions",
        "es": "Dimensiones"
      }
    },
    {
      "id": "joint",
      "label": {
        "en": "Joint",
        "es": "Articulación"
      }
    },
    {
      "id": "quality",
      "label": {
        "en": "Quality",
        "es": "Calidad"
      }
    }
  ],
  "export_formats": [
    "stl",
    "3mf",
    "off",
    "glb",
    "obj"
  ],
  "estimate_constants": {
    "base_time": 5,
    "per_unit": 2,
    "per_part": 8,
    "fn_factor": 32,
    "wasm_multiplier": 3,
    "warning_threshold_seconds": 60
  },
  "hyperobject": {
    "domain": "industrial",
    "cdg_interfaces": [
      {
        "id": "revolute_axis",
        "label": {
          "en": "Revolute Axis Interface",
          "es": "Interfaz de Eje de Rotación"
        },
        "geometry_type": "rail",
        "standard": "internal",
        "parameters": [
          "pin_diameter",
          "hinge_width"
        ]
      },
      {
        "id": "mounting_surface",
        "label": {
          "en": "Mounting Surface",
          "es": "Superficie de Montaje"
        },
        "geometry_type": "surface",
        "standard": "internal",
        "parameters": [
          "leaf_length",
          "hinge_width"
        ]
      }
    ],
    "material_awareness": {
      "shrinkage_compensation": true,
      "recycled_material_toggle": false,
      "tolerance_by_material": true
    },
    "societal_benefit": {
      "en": "Universal parametric hinges for mechanical assemblies — enables rapid prototyping of enclosures, robotics, and functional mechanisms",
      "es": "Bisagras paramétricas universales para ensamblajes mecánicos — permite prototipado rápido de gabinetes, robótica y mecanismos funcionales"
    },
    "commons_license": "CERN-OHL-W-2.0"
  }
}
